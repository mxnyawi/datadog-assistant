{
  "auth": "keys",
  "api_key": "",
  "app_key": "",
  "use_keychain": true,
  "api_key_cmd": "",
  "app_key_cmd": "",
  "oauth_client_id": "",
  "oauth_domain": "",
  "site": "datadoghq.com",
  "app_subdomain": "app",
  "browser": "",
  "refresh_seconds": 60,
  "tag_filter": "team:payments env:prod",
  "name_filter": "",
  "notifications": {
    "enabled": true,
    "style": "both",
    "sound": true,
    "sound_name": "Sosumi",
    "notify_on_warn": true,
    "notify_on_no_data": true,
    "notify_on_recovery": true,
    "renotify_minutes": 30
  },
  "icons": {
    "ok": "🐶",
    "alert": "🚨",
    "warn": "⚠️",
    "no_data": "🤷",
    "snoozed": "😴",
    "error": "🔌",
    "show_count": true
  },
  "menu": {
    "show_ok_monitors": true,
    "max_per_group": 25,
    "group_order": ["Alert", "Warn", "No Data", "OK", "Muted"]
  },
  "severity": {
    "rules": {
      "p1": {"style": "both", "renotify_minutes": 10, "icon": "‼️", "sound_name": "Sosumi"},
      "p2": {"style": "both", "renotify_minutes": 30, "icon": "🚨"},
      "p3": {"style": "banner", "renotify_minutes": 60},
      "default": {}
    }
  },
  "context": {
    "show_triggered_groups": true,
    "max_groups_shown": 3,
    "show_sparkline": true,
    "sparkline_window_minutes": 60,
    "show_incidents": true,
    "auto_dashboard_links": true,
    "max_dashboards": 8
  },
  "no_data_triage": {
    "enabled": true,
    "stale_hours": 48,
    "probe_lookback_hours": 24,
    "max_probes": 6
  },
  "dlq": {
    "enabled": true,
    "patterns": ["dlq", "dead letter", "dead-letter", "dead_letter", "deadletter"],
    "match_query": true,
    "match_tags": true,
    "exclusive": true
  },
  "github": {
    "enabled": false,
    "auth": "oauth",
    "token": "",
    "token_cmd": "",
    "oauth_client_id": "",
    "oauth_scopes": "repo",
    "api_base": "https://api.github.com",
    "default_org": "your-org",
    "auto_discover": true,
    "max_discover_per_poll": 3,
    "discover_hit_ttl_hours": 168,
    "discover_miss_ttl_hours": 6,
    "repo_map": {
      "service:payments": "your-org/payments-api",
      "checkout": "your-org/checkout"
    },
    "deploy_environments": ["production", "prod"],
    "lookback_hours": 24,
    "correlate_minutes": 120,
    "max_items": 4,
    "show_on": ["Alert", "Warn", "No Data"],
    "notify_correlation": true,
    "cache_seconds": 180,
    "max_repos_per_poll": 6
  },
  "digest_hour": 9,
  "jira": {
    "enabled": false,
    "auth": "token",
    "base_url": "https://yourcompany.atlassian.net",
    "email": "you@company.com",
    "api_token": "",
    "api_token_cmd": "",
    "oauth_client_id": "",
    "cloud_id": "",
    "project_key": "OPS",
    "issue_type": "Task",
    "labels": ["datadog-alert"],
    "auto_label_from_tags": true,
    "auto_create": false,
    "auto_create_max_p": 2,
    "dedupe": true
  },
  "quick_links": [
    {"name": "📊 Dashboards", "path": "/dashboard/lists"},
    {"name": "📟 Monitors", "path": "/monitors/manage"},
    {"name": "🪵 Logs", "path": "/logs"},
    {"name": "🧵 APM Traces", "path": "/apm/traces"},
    {"name": "🔥 Incidents", "path": "/incidents"},
    {"name": "🏠 Infrastructure", "path": "/infrastructure"}
  ],
  "custom_links": [
    {"name": "💳 Payments Dashboard", "url": "https://app.datadoghq.com/dashboard/abc-123"},
    {"name": "📕 Runbook (Confluence)", "url": "https://example.atlassian.net/wiki/runbooks"}
  ]
}
